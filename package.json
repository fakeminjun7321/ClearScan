{
  "name": "clearscan",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "backend": "node server/index.mjs",
    "web": "vite --config web/vite.config.ts --host 0.0.0.0 --port 4173",
    "mobile": "vite --host 0.0.0.0 --port 4175",
    "build:web": "vite build --config web/vite.config.ts",
    "check:web": "tsc -p web/tsconfig.json --noEmit",
    "test:web": "playwright test --config web.playwright.config.ts",
    "test:backend": "node --test tests/backend-api.test.mjs",
    "check:runtime": "node scripts/check-mobile-runtime.mjs",
    "update:runtime-lock": "node scripts/update-mobile-runtime-lock.mjs",
    "test:runtime": "playwright test",
    "test:sites": "node --test tests/sites-worker.test.mjs",
    "predev": "npm run check:runtime",
    "dev": "vite",
    "prebuild": "npm run check:runtime",
    "build": "tsc && vite build && node scripts/prepare-sites-build.mjs"
  },
  "dependencies": {
    "@fontsource/roboto": "5.2.10",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-dropdown-menu": "2.1.20",
    "@radix-ui/react-icons": "1.3.2",
    "@use-gesture/react": "10.3.1",
    "jszip": "^3.10.1",
    "motion": "12.42.2",
    "pdf-lib": "^1.17.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "7.0.2",
    "vite": "8.1.3"
  }
}
